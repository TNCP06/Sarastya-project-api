# SaraDrive API — environment (consumed by docker-compose in the umbrella repo).
# In production these come from the umbrella ~/scd/.env; this file documents the keys.

# Postgres connection (scd-postgres service). DB name/user/password match the umbrella stack.
ConnectionStrings__Default=Host=scd-postgres;Port=5432;Database=scd;Username=scd;Password=

# JWT signing — HS256. Use a long random secret (>= 32 bytes). Token lifetime in hours.
Jwt__Secret=
Jwt__ExpiresInHours=24

# Comma-separated browser origins allowed to call the API directly (CORS).
# In prod the web calls the API server-side via the /papi/* rewrite, so this is mainly
# for local dev (the Next dev server) and the Swagger UI.
AllowedOrigins=http://localhost:3000,http://localhost:3100
